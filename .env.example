#npx playwright test tests/flows/happypath/flujoCompletoCliente.spec.ts

#Modo UI (interactivo)
#npx playwright test --ui

#Modo debug
#npx playwright test --debug

#Ver reporte después de ejecutar
#npx playwright show-report

