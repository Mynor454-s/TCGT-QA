{
  "name": "playwright",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:regression": "npx playwright test --grep \"@P0|@P1\"",
    "test:regression:e2e": "npx playwright test tests/E2E/regression/",
    "test:regression:b2c": "npx playwright test tests/B2C/regression/",
    "test:stories": "npx playwright test tests/E2E/stories/ tests/B2C/stories/",
    "test:chrome": "npx playwright test --project=Chrome",
    "test:browserstack": "npx browserstack-node-sdk playwright test --config=./playwright.bs.config.js",
    "test:bs:regression": "npx browserstack-node-sdk playwright test tests/E2E/regression/ tests/B2C/regression/ --config=./playwright.bs.config.js",
    "test:bs:smoke": "npx browserstack-node-sdk playwright test --grep @smoke --config=./playwright.bs.config.js",
    "report": "npx playwright show-report",
    "server": "npx cross-env PORT=3001 ts-node server/index.ts",
    "server:dev": "npx cross-env PORT=3001 ts-node --watch server/index.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@playwright/test": "^1.56.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "browserstack-node-sdk": "latest",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1"
  }
}
